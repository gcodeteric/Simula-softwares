# ===========================================
# Simula Setups — Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# ---- Database ----
DATABASE_URL=postgresql://simula:simula_dev@localhost:5432/simula_setups

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- API Server ----
API_PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development

# ---- Web App (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production

# ---- Storage (Cloudflare R2 / S3) ----
# For local dev, files are stored on filesystem. Set these for R2:
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=simula-setups
# R2_PUBLIC_URL=
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage

# ---- Auth (future: Simula Hub SSO) ----
# AUTH_PROVIDER=hub
# HUB_ISSUER_URL=https://hub.simulaproject.com
# HUB_CLIENT_ID=
# HUB_CLIENT_SECRET=
AUTH_PROVIDER=mock
